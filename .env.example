# Copy to .env and fill in. The harness loads this automatically (python-dotenv).

# --- API keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Models (optional overrides) ---
# Anthropic slot (default proposer). See model IDs in README.
ANTHROPIC_MODEL=claude-opus-4-8
# OpenAI slot (default skeptic). Override if you want a different OpenAI model.
OPENAI_MODEL=gpt-4o
# Orchestrator + observe-only judge run on Anthropic.
ORCHESTRATOR_MODEL=claude-opus-4-8
