# Copy to .env and fill in. The harness loads this automatically (python-dotenv).

# --- API keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Optional: one key to reach Anthropic/OpenAI/Google/Llama/etc. via OpenRouter.
OPENROUTER_API_KEY=sk-or-...

# --- Models (optional overrides) ---
# Legacy per-vendor model overrides (still honored as the model fallback).
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
ORCHESTRATOR_MODEL=claude-opus-4-8

# --- Per-role provider + model (optional) ------------------------------------
# Each of the four endpoints can be pointed at any provider+model. Provider is
# anthropic | openai | openrouter. OpenRouter models are vendor/model slugs.
# Unset = today's defaults; the judge mirrors the orchestrator unless set.
# Precedence: CLI flag > these > legacy *_MODEL above > built-in default.
#
# SLOT_A_PROVIDER=anthropic
# SLOT_A_MODEL=claude-opus-4-8
# SLOT_B_PROVIDER=openai
# SLOT_B_MODEL=gpt-4o
# ORCHESTRATOR_PROVIDER=anthropic
# JUDGE_PROVIDER=openrouter          # e.g. route the every-turn judge to a cheap model
# JUDGE_MODEL=anthropic/claude-3.5-haiku
